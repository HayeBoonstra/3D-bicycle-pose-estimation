<mujoco model="bicycle">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.01"/>

    <size njmax="100" nconmax="50"/>

    <default>
        <joint limited="true" damping="1"/>
        <geom friction="0.8 0.1 0.1" rgba="0.8 0.6 0.4 1"/>
    </default>

    <worldbody>
        <!-- Ground -->
        <geom name="ground" type="plane" size="5 5 0.1" rgba="0.7 0.9 0.7 1" contype="1" conaffinity="1"/>
        
        <!-- Bike Frame -->
        <body name="frame" pos="0 0 0.35">
            <geom name="frame_base" type="capsule" fromto="0 0 0  0.6 0 0" size="0.03"/>
            <geom name="frame_seat" type="capsule" fromto="0.13 0 0  0.13 0 0.25" size="0.025"/>

            <!-- Rear wheel -->
            <body name="rear_wheel" pos="0 0 0">
                <joint name="rear_wheel_hinge" type="hinge" axis="0 1 0" pos="0 0 0"/>
                <geom name="rear_wheel_geom" type="cylinder" size="0.11 0.025" rgba="0.1 0.1 0.1 1"/>
            </body>
            
            <!-- Fork and Front wheel -->
            <body name="front_fork" pos="0.6 0 0">
                <!-- Steering joint -->
                <joint name="steer" type="hinge" axis="0 0 1" pos="0 0 0" range="-35 35"/>
                <geom name="fork_bar" type="capsule" fromto="0 0 0  0 0 0.14" size="0.016"/>
                <body name="front_wheel" pos="0 0 0">
                    <joint name="front_wheel_hinge" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="front_wheel_geom" type="cylinder" size="0.11 0.025" rgba="0.1 0.1 0.1 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor joint="rear_wheel_hinge" gear="30"/>
        <motor joint="steer" gear="2"/>
    </actuator>
</mujoco>